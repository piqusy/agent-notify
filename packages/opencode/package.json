{
  "name": "opencode-agent-notify",
  "version": "0.2.0",
  "description": "OpenCode plugin for agent-notify notifications",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-notify/core": "workspace:*"
  },
  "peerDependencies": {
    "opencode-ai": "*"
  },
  "peerDependenciesMeta": {
    "opencode-ai": {
      "optional": true
    }
  },
  "keywords": [
    "opencode",
    "notifications",
    "agent-notify"
  ],
  "license": "MIT"
}
